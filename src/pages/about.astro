---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { siteConfig } from '../site.config';
import { withBase } from '../lib/url';
---
<BaseLayout title="About" description={`About ${siteConfig.author} and this blog.`}>
  <Breadcrumbs items={[{ label: 'Home', href: withBase('/') }, { label: 'About' }]} />
  <article class="about">
    <header class="about-header">
      <div class="avatar" aria-hidden="true">{siteConfig.author.charAt(0)}</div>
      <div>
        <h1>Hi, I'm {siteConfig.author}.</h1>
        <p class="muted">Writing about books, software, learning, and whatever else I find worth sharing.</p>
      </div>
    </header>

    <h2>About this space</h2>
    <p>
      This is where I share things I find worth writing about — books I've read,
      software I've built, activities I've picked up, and lessons learned along the way.
      No single topic, just whatever I'm thinking about.
    </p>

    <h2>What you'll find here</h2>
    <ul>
      <li>Notes on books and ideas</li>
      <li>Things I've built or learned while building software</li>
      <li>New activities and hobbies I'm exploring</li>
      <li>Thoughts I want to get out of my head and onto a page</li>
    </ul>

    <h2>Get in touch</h2>
    <p>
      Reach out via the <a href={withBase('/contact/')}>contact form</a>
      or email me at <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
    </p>
    <p class="cta-row">
      <a class="btn btn-primary" href={withBase('/contact/')}>Get in touch</a>
    </p>

    <h2>Elsewhere</h2>
    <p>
      <a href={siteConfig.social.github} target="_blank" rel="me">GitHub</a> ·
      <a href={siteConfig.social.linkedin} target="_blank" rel="me">LinkedIn</a>
    </p>
  </article>

  <style>
    .about { max-width: var(--content-width); }
    .about-header {
      display: flex;
      gap: 1rem;
      align-items: center;
      margin-bottom: 1.5rem;
    }
    .about-header h1 { margin: 0 0 0.25rem; }
    .about-header p { margin: 0; }
    .avatar {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent-soft));
      color: var(--accent-fg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      font-weight: 700;
      flex-shrink: 0;
    }
    .cta-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  </style>
</BaseLayout>
