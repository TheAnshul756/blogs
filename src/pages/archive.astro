---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getArchive, formatDate } from '../lib/posts';

const archive = await getArchive();
const keys = [...archive.keys()].sort().reverse();
const monthName = (ym: string) => {
  const [y, m] = ym.split('-').map(Number);
  return new Date(y, m - 1, 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
};
---
<BaseLayout title="Archive" description="All posts by month.">
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Archive' }]} />
  <header class="page-header">
    <h1>Archive</h1>
    <p class="muted">All posts organized by month.</p>
  </header>

  {keys.map((ym) => (
    <section class="archive-month">
      <h2>{monthName(ym)}</h2>
      <ul>
        {archive.get(ym)!.map((p) => (
          <li>
            <time datetime={p.data.pubDate.toISOString()} class="muted small">
              {formatDate(p.data.pubDate)}
            </time>
            <a href={`/posts/${p.id}/`}>{p.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  ))}

  <style>
    .page-header h1 { margin: 0 0 0.25rem; }
    .archive-month { margin: 1.5rem 0; }
    .archive-month h2 { font-size: 1.1rem; margin: 0 0 0.5rem; color: var(--fg-muted); }
    .archive-month ul { list-style: none; padding: 0; margin: 0; }
    .archive-month li {
      display: grid;
      grid-template-columns: 7rem 1fr;
      gap: 0.75rem;
      padding: 0.35rem 0;
      border-bottom: 1px solid var(--border);
      align-items: baseline;
    }
    .archive-month li:last-child { border-bottom: none; }
    .archive-month a { color: var(--fg); }
    .archive-month a:hover { color: var(--accent); }
  </style>
</BaseLayout>
