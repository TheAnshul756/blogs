---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllSeries, slugify } from '../../lib/posts';

export async function getStaticPaths() {
  const series = await getAllSeries();
  return [...series.entries()].map(([name, posts]) => ({
    params: { series: slugify(name) },
    props: { name, posts },
  }));
}

const { name, posts } = Astro.props;
---
<BaseLayout title={name} description={`The ${name} series.`}>
  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: 'Series', href: '/series' },
    { label: name },
  ]} />
  <header class="page-header">
    <h1>{name}</h1>
    <p class="muted">{posts.length} parts, in order.</p>
  </header>
  <ol class="series-ordered">
    {posts.map((p, i) => (
      <li>
        <span class="num">{i + 1}.</span>
        <PostCard post={p} />
      </li>
    ))}
  </ol>

  <style>
    .page-header { margin: 0.5rem 0 1rem; }
    .page-header h1 { margin: 0 0 0.25rem; }
    .series-ordered { list-style: none; padding: 0; margin: 0; }
    .series-ordered li {
      display: grid;
      grid-template-columns: 2rem 1fr;
      gap: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    .series-ordered li:last-child { border-bottom: none; }
    .series-ordered .num {
      color: var(--fg-faint);
      font-variant-numeric: tabular-nums;
      padding-top: 1.35rem;
    }
  </style>
</BaseLayout>
