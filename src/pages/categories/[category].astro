---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllCategories } from '../../lib/posts';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const cats = await getAllCategories();
  return [...cats.entries()].map(([cat, posts]) => ({
    params: { category: cat.toLowerCase() },
    props: { category: cat, posts },
  }));
}

const { category, posts } = Astro.props;
---
<BaseLayout title={category} description={`Posts in the ${category} category.`}>
  <Breadcrumbs items={[
    { label: 'Home', href: withBase('/') },
    { label: 'Categories', href: withBase('/categories/') },
    { label: category },
  ]} />
  <header class="page-header">
    <h1>{category}</h1>
    <p class="muted">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
  </header>
  {posts.map((p) => <PostCard post={p} />)}

  <style>
    .page-header { margin: 0.5rem 0 1rem; }
    .page-header h1 { margin: 0 0 0.25rem; }
  </style>
</BaseLayout>
