---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PostCard from '../../components/PostCard.astro';
import Search from '../../components/Search.astro';
import { getAllPosts } from '../../lib/posts';

const posts = await getAllPosts();
---
<BaseLayout title="All posts" description="Every post on the site.">
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Posts' }]} />
  <header class="page-header">
    <h1>All posts</h1>
    <p class="muted">{posts.length} {posts.length === 1 ? 'post' : 'posts'} total.</p>
  </header>
  <Search />
  <section>
    {posts.map((p) => <PostCard post={p} />)}
  </section>

  <style>
    .page-header { margin: 0.5rem 0 1rem; }
    .page-header h1 { margin: 0 0 0.25rem; }
  </style>
</BaseLayout>
