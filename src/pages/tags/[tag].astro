---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllTags } from '../../lib/posts';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return [...tags.entries()].map(([tag, posts]) => ({
    params: { tag },
    props: { tag, posts },
  }));
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag}`} description={`Posts tagged with ${tag}.`}>
  <Breadcrumbs items={[
    { label: 'Home', href: withBase('/') },
    { label: 'Tags', href: withBase('/tags/') },
    { label: `#${tag}` },
  ]} />
  <header class="page-header">
    <h1>#{tag}</h1>
    <p class="muted">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
  </header>
  {posts.map((p) => <PostCard post={p} />)}

  <style>
    .page-header { margin: 0.5rem 0 1rem; }
    .page-header h1 { margin: 0 0 0.25rem; }
  </style>
</BaseLayout>
