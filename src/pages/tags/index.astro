---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getAllTags } from '../../lib/posts';
import { withBase } from '../../lib/url';

const tags = await getAllTags();
const entries = [...tags.entries()].sort((a, b) => b[1].length - a[1].length);
---
<BaseLayout title="Tags" description="All tags on the blog.">
  <Breadcrumbs items={[{ label: 'Home', href: withBase('/') }, { label: 'Tags' }]} />
  <header class="page-header">
    <h1>Tags</h1>
    <p class="muted">Browse posts by tag.</p>
  </header>
  <div class="tag-cloud">
    {entries.map(([tag, posts]) => (
      <a class="chip big" href={withBase(`/tags/${tag}/`)}>
        #{tag} <span class="count">{posts.length}</span>
      </a>
    ))}
  </div>

  <style>
    .tag-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }
    .chip.big {
      font-size: 0.95rem;
      padding: 0.35rem 0.75rem;
    }
    .count {
      background: var(--bg);
      border-radius: 999px;
      padding: 0 0.4rem;
      margin-left: 0.25rem;
      font-size: 0.8rem;
      color: var(--fg-muted);
    }
    .page-header h1 { margin: 0 0 0.25rem; }
  </style>
</BaseLayout>
