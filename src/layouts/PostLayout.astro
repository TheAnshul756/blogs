---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TOC from '../components/TOC.astro';
import ShareButtons from '../components/ShareButtons.astro';
import Reactions from '../components/Reactions.astro';
import Comments from '../components/Comments.astro';
import PostCard from '../components/PostCard.astro';
import { formatDate, getReadingTime, getRelatedPosts, getAllSeries } from '../lib/posts';

interface Props {
  post: CollectionEntry<'posts'>;
  headings: { depth: number; slug: string; text: string }[];
}
const { post, headings } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site ?? 'https://example.com').toString();
const rt = getReadingTime(post.body);
const related = await getRelatedPosts(post, 3);

let seriesPosts: CollectionEntry<'posts'>[] = [];
if (post.data.series) {
  const all = await getAllSeries();
  seriesPosts = all.get(post.data.series) ?? [];
}
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
  tags={post.data.tags}
  showProgress
>
  <div class="post-wrap">
    <article class="post" data-pagefind-body>
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Posts', href: '/posts' },
        { label: post.data.title }
      ]} />

      <header class="post-header">
        <h1 data-pagefind-meta="title">{post.data.title}</h1>
        <p class="post-meta muted small">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <span>•</span>
          <span>{rt}</span>
          <span>•</span>
          <a href={`/categories/${post.data.category.toLowerCase()}/`}>{post.data.category}</a>
          {post.data.updatedDate && (
            <>
              <span>•</span>
              <span>Updated {formatDate(post.data.updatedDate)}</span>
            </>
          )}
        </p>
        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((t) => (
              <a class="chip" href={`/tags/${t.toLowerCase()}/`} data-pagefind-filter={`tag:${t}`}>#{t}</a>
            ))}
          </div>
        )}
        <p class="post-desc muted">{post.data.description}</p>
      </header>

      {seriesPosts.length > 1 && (
        <aside class="series-box">
          <p class="series-title">
            Part of the series: <a href={`/series/${post.data.series!.toLowerCase().replace(/\s+/g, '-')}/`}>{post.data.series}</a>
          </p>
          <ol>
            {seriesPosts.map((sp) => (
              <li class={sp.id === post.id ? 'current' : ''}>
                {sp.id === post.id ? sp.data.title : <a href={`/posts/${sp.id}/`}>{sp.data.title}</a>}
              </li>
            ))}
          </ol>
        </aside>
      )}

      <div class="post-body">
        <slot />
      </div>

      <ShareButtons title={post.data.title} url={url} />
      <Reactions slug={post.id} />

      {related.length > 0 && (
        <section class="related">
          <h2>Related posts</h2>
          {related.map((r) => <PostCard post={r} />)}
        </section>
      )}

      <Comments />
    </article>
    <aside class="post-aside">
      <TOC headings={headings} />
    </aside>
  </div>

  <style>
    .post-wrap {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 240px;
      gap: 3rem;
      align-items: start;
    }
    .post {
      max-width: var(--content-width);
      width: 100%;
    }
    .post-header { margin-bottom: 1.5rem; }
    .post-header h1 { margin: 0.25rem 0 0.5rem; font-size: 2.25rem; }
    .post-meta { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; margin: 0 0 0.75rem; }
    .post-tags { margin-bottom: 0.75rem; }
    .post-desc { font-size: 1.05rem; margin: 0.5rem 0 0; }
    .post-body > :first-child { margin-top: 0; }
    .series-box {
      padding: 1rem;
      border: 1px solid var(--border);
      background: var(--bg-elev);
      border-radius: var(--radius);
      margin: 1.5rem 0;
    }
    .series-title { margin: 0 0 0.5rem; font-weight: 500; }
    .series-box ol { margin: 0; padding-left: 1.2rem; }
    .series-box li.current { font-weight: 600; color: var(--accent); }
    .related { margin-top: 2.5rem; }
    .related h2 { margin-bottom: 0.5rem; }
    .post-aside {
      position: relative;
    }
    @media (max-width: 1100px) {
      .post-wrap { grid-template-columns: 1fr; }
      .post-aside { order: -1; }
      .post-aside .toc {
        position: static;
        max-height: none;
        margin-bottom: 1rem;
      }
    }
  </style>
</BaseLayout>
